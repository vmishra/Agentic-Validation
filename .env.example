# Aegis configuration — copy this file to .env and fill in your key:
#     cp .env.example .env
#
# .env is git-ignored. Never commit real keys.

# ── Required ──────────────────────────────────────────────────────────────────
# Google AI Studio (Gemini Developer API) key. Get a free key at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Model / auth ──────────────────────────────────────────────────────────────
# Use the Gemini Developer API (AI Studio), not Vertex AI. Leave as false.
GOOGLE_GENAI_USE_VERTEXAI=false
# Model used by every validator agent (any current Gemini model id).
AEGIS_MODEL=gemini-3.5-flash

# ── Optional ──────────────────────────────────────────────────────────────────
# Wall-clock backstop for a single scan, in seconds (default 300).
# AEGIS_RUN_TIMEOUT=300
# Where completed reports are stored (default: ./.aegis-history).
# AEGIS_HISTORY_DIR=

# Ports are set on the shell, not here (they're read by app.sh / Vite, not the backend):
#   AEGIS_FE_PORT=5176 AEGIS_BE_PORT=8791 ./app.sh start
